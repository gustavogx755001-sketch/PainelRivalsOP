   end,
})

-- Aba Aimbot
AimbotTab:CreateToggle({
   Name = "Ativar Aimbot",
   CurrentValue = false,
   Callback = function(Value)
      AimbotEnabled = Value
      FovCircle.Visible = Value 
      
      -- Limpa o alvo atual ao desligar
      if not Value then
          CurrentAimbotTarget = nil
          RunService:UnbindFromRenderStep("ChosoAimbotLock")
      else
          -- Bind de alta prioridade para ultra precisão sem engasgos
          RunService:BindToRenderStep("ChosoAimbotLock", Enum.RenderPriority.Camera.Value + 1, loopDoAimbot)
      end
   end,
})

AimbotTab:CreateSlider({
   Name = "Fov",
   Range = {10, 700},
   Increment = 5,
   Suffix = " Raio",
   CurrentValue = 100,
   Callback = function(Value)
